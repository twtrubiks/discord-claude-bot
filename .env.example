# Discord Bot Token（必填，從 Discord Developer Portal 取得）
DISCORD_BOT_TOKEN=your_discord_bot_token

# 用戶白名單（選填，逗號分隔；留空代表不啟用白名單）
# Discord: 開啟開發者模式 → 右鍵點擊你的名字 → 複製用戶 ID
ALLOWED_USER_IDS=

# Groq API Key（選填，語音轉文字功能需要，未設定時語音訊息僅存檔）
# 從 https://console.groq.com/ 取得
GROQ_API_KEY=

# Discord 伺服器 ID（選填，設定後 slash commands 即時生效，不設則需等最多 1 小時）
# 取得方式：開啟開發者模式 → 右鍵點擊伺服器名稱 → 複製伺服器 ID
DISCORD_GUILD_ID=

# 對話管理設定（選填）
# MAX_MESSAGES_BEFORE_COMPRESS=16  # 超過此數量時觸發摘要壓縮

# Streaming 設定（選填）
# STREAM_ENABLED=true  # 設為 false 可關閉串流輸出，改回等待完整回應後一次送出

# Claude 模型（選填，留空或註解掉則使用 CLI 預設模型）
# 可用別名 opus / sonnet / haiku，或完整 ID 如 claude-opus-4-8、claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-8

# 輕量任務模型（選填，用於摘要壓縮、cron 標題生成這類簡單任務，省成本）
# 未設定時退回 CLAUDE_MODEL；主對話與事實萃取不受影響
# CLAUDE_LIGHT_MODEL=claude-haiku-4-5
