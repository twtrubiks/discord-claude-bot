# Discord Bot Token（必填，從 Discord Developer Portal 取得）
DISCORD_BOT_TOKEN=your_discord_bot_token

# 用戶白名單（選填，逗號分隔；留空代表不啟用白名單）
# Discord: 開啟開發者模式 → 右鍵點擊你的名字 → 複製用戶 ID
ALLOWED_USER_IDS=

# Groq API Key（選填，語音轉文字功能需要，未設定時語音訊息僅存檔）
# 從 https://console.groq.com/ 取得
GROQ_API_KEY=

# 對話管理設定（選填）
# MAX_MESSAGES_BEFORE_COMPRESS=16  # 超過此數量時觸發摘要壓縮
